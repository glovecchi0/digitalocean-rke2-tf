## -- Specifies the prefix added to the names of all resources.
prefix = "do-rke2"

## -- DigitalOcean API token used to deploy the infrastructure.
do_token = null

## -- Specifies the DigitalOcean region used for all resources.
region = "fra1"

## -- Existing SSH key ID to use. If null, module will use or create one.
do_ssh_key_id = null

## -- Specifies the number of Droplets (nodes) to create for the RKE2 cluster.
instance_count = 1

## -- Specifies the name of the DigitalOcean Droplet type.
instance_type = "g-16vcpu-64gb"

## -- Specifies the size of the additional data disks attached to the Droplet, in GB.
data_disk_size = 350

## -- Specifies the ID of the custom OS image used to provision all RKE2 cluster droplets.
image_id = ""

## -- Specifies cloud-init user_data used to bootstrap the Droplet.
user_data = null

## -- Specifies the RKE2 node role for this instance.
node_role = "agent"

## -- Specifies the shared token used by all nodes to join the RKE2 cluster.
rke2_token = "SecretToken.123"

## -- Specifies the RKE2 version to install.
rke2_version = "v1.35.4+rke2r1"

## -- Specifies the URL of the first RKE2 server node.
server_url = null

## -- Specifies additional custom RKE2 configuration in YAML format.
rke2_config = ""

## -- Specifies the ingress controller to deploy.
rke2_ingress = "traefik"

## -- Specifies whether Longhorn should be installed on the Kubernetes cluster.
longhorn_enabled = false

## -- Specifies the Longhorn Helm chart version to install.
longhorn_version = null

## -- Specifies whether Rancher should be installed on the Kubernetes cluster.
rancher_enabled = false

## -- Specifies the Rancher Helm chart version to install.
rancher_version = null

## -- Specifies the bootstrap administrator password used during Rancher installation. Must be at least 12 characters when Rancher is enabled.
rancher_bootstrap_password = null

## -- Specifies the TLS certificate source used by Rancher.
rancher_tls_source = "letsEncrypt"

## -- Specifies whether SUSE Observability should be installed on the Kubernetes cluster.
suse_observability_enabled = false

## -- Specifies the SUSE Observability Helm chart version to install.
suse_observability_version = null

## -- Specifies the SUSE Observability license key required for installation.
suse_observability_license = null

## -- Specifies the SUSE Observability administrator password used during installation. Must be at least 12 characters when enabled.
suse_observability_admin_password = null
